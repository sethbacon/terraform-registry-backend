# Normalize line endings to LF in the repo; check out as-is on all platforms.
* text=auto eol=lf

# Explicitly LF for Go and common text files
*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.sql   text eol=lf
*.sh    text eol=lf
*.env   text eol=lf
*.txt   text eol=lf

# Binary files — never touch line endings
*.zip   binary
*.tar   binary
*.gz    binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.exe   binary
