# Git
.git
.gitignore

# Documentation
*.md
# Include only the files needed for the embedded swagger spec.
# swagger.json and openapi3.json are committed to the repo (auto-generated
# by CI — see .github/workflows/ci.yml).
docs/
!docs/embed.go
!docs/swagger.json
!docs/openapi3.json
!docs/swagger-ui/

# Development files
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts
terraform-registry
*.exe
*.test
*.out

# Test files
*_test.go
testdata/

# Configuration (will be mounted)
config.yaml
config.yml
*.env

# Storage (will be mounted)
storage/
data/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Logs
*.log
logs/
